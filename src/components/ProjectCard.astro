---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description: string;
  location: string;
  year: number;
  coverImage: ImageMetadata;
  slug: string;
  locale: 'it' | 'en';
  index?: number;
}

const { title, location, year, coverImage, slug, locale, index } = Astro.props;
const projectUrl = `/${locale === 'it' ? 'progetti' : 'en/projects'}/${slug}`;
const numberLabel = typeof index === 'number' ? String(index + 1).padStart(2, '0') : null;
---

<a href={projectUrl} class="group block">
  <div class="relative overflow-hidden aspect-[4/5] bg-gray-100">
    <Image
      src={coverImage}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
      widths={[400, 600, 800, 1000]}
      sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
    />
  </div>
  <div class="pt-6">
    {numberLabel && (
      <div class="mb-3">
        <span class="text-xs font-light text-gray-400 tabular-nums">{numberLabel}</span>
      </div>
    )}
    <h3 class="text-xl md:text-2xl font-light leading-tight tracking-tight text-gray-900 mb-3 transition-colors group-hover:text-black">
      {title}
    </h3>
    <div class="text-sm text-gray-500 tracking-wide">
      <span>{location}</span>
      <span class="mx-2 text-gray-300">·</span>
      <span>{year}</span>
    </div>
  </div>
</a>
