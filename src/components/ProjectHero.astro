---
import { Image } from 'astro:assets';
import heroImage from '../assets/projects-hero.webp';

interface Props {
  title: string;
  subtitle: string;
  eyebrow?: string;
  tag?: string;
  locale: 'it' | 'en';
}

const { title, subtitle, eyebrow, tag } = Astro.props;
---

<section class="relative bg-gray-900 overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0">
    <Image
      src={heroImage}
      alt=""
      class="w-full h-full object-cover"
      widths={[1200, 1600, 2000, 2400]}
      sizes="100vw"
    />
    <!-- Gradient overlay for legibility -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/35 via-black/45 to-black/80"></div>
  </div>

  <!-- Content -->
  <div class="relative min-h-[72vh] md:min-h-[78vh] flex flex-col justify-end">
    <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8 w-full pt-40 pb-14 md:pb-20">
      <div class="grid md:grid-cols-12 gap-10 md:gap-12 items-end">
        <div class="md:col-span-7">
          {eyebrow && (
            <p class="text-[11px] tracking-[0.2em] sm:tracking-[0.35em] uppercase text-white/75 mb-5 md:mb-6">{eyebrow}</p>
          )}
          <h1 class="text-3xl sm:text-5xl md:text-6xl lg:text-7xl font-extralight leading-[1.05] sm:leading-[1.02] tracking-[-0.01em] text-white">
            {title}
          </h1>
        </div>
        <div class="md:col-span-5 space-y-5">
          <p class="text-base md:text-lg leading-[1.55] font-light text-white/85 max-w-xl">
            {subtitle}
          </p>
          {tag && (
            <p class="text-[11px] tracking-[0.25em] uppercase text-white/55">{tag}</p>
          )}
        </div>
      </div>
    </div>
  </div>
</section>
