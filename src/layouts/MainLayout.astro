---
import BaseLayout from './BaseLayout.astro';
import { Image } from 'astro:assets';
import palauCover from '../assets/real-estate/palau-barrabisa/home-hero.jpg';

interface Props {
  content: any;
  locale: 'it' | 'en';
}

const { content, locale } = Astro.props;
const projectsUrl = locale === 'it' ? '/progetti' : '/en/projects';
const realEstateUrl = locale === 'it' ? '/real-estate' : '/en/real-estate';
const h = content.home_sections;
---

<BaseLayout content={content} locale={locale}>
	<!-- Hero Section -->
	<section id="home" class="relative h-screen flex items-center overflow-hidden">
		<div class="absolute inset-0 z-0">
			<img src="/img/ChatGPT Image Dec 5, 2025, 12_57_10 PM.png" alt="" class="w-full h-full object-cover" />
			<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/45 to-black/20"></div>
		</div>
		<div class="relative z-10 w-full pl-6 sm:pl-10 md:pl-16 lg:pl-24 pr-4 text-white -mt-8 md:-mt-16">
			<div class="max-w-md md:max-w-lg lg:max-w-xl">
				<p class="text-xs md:text-sm tracking-[0.3em] uppercase text-white/70 mb-6">{content.hero.eyebrow}</p>
				<h1 class="text-5xl md:text-6xl lg:text-7xl font-light leading-[1.05] tracking-tight mb-8 md:mb-10" set:html={content.hero.subtitle}></h1>
				<p class="text-base md:text-lg text-white/80 font-light leading-relaxed mb-5 md:mb-6">{content.hero.body}</p>
				<p class="text-[11px] md:text-xs tracking-[0.2em] uppercase text-white/50 italic mb-8">{content.hero.trust}</p>
				<div class="flex items-center gap-4 text-xs md:text-sm tracking-widest uppercase text-white/70">
					<span>Est. 2001</span>
					<span class="w-1 h-1 bg-white/50 rounded-full"></span>
					<span>A Tiesse Group company</span>
				</div>
			</div>
		</div>
	</section>

	<!-- KEY STATS STRIP -->
	<section class="bg-white border-b border-gray-200">
		<div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8">
			<div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-gray-200">
				{content.key_facts.items.map((item: { value: string; label: string }) => (
					<div class="py-10 px-4 md:px-6 text-center">
						<div class="text-3xl md:text-5xl font-light text-gray-900 mb-2">{item.value}</div>
						<div class="text-[11px] md:text-xs tracking-widest uppercase text-gray-500">{item.label}</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- 01 — ABOUT -->
	<section id={locale === 'it' ? 'chi-siamo' : 'about'} class="py-28 md:py-40 bg-white border-b border-gray-200">
		<div class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16">
			<div class="grid md:grid-cols-12 gap-10 md:gap-16 items-end">
				<div class="md:col-span-7">
					<p class="text-[10px] md:text-xs tracking-[0.3em] uppercase text-gray-400 mb-10">01 — {h.about_eyebrow}</p>
					<h2 class="text-3xl md:text-5xl font-light leading-tight tracking-tight text-gray-900">
						{h.about_title}
					</h2>
				</div>
				<div class="md:col-span-5">
					<p class="text-base md:text-lg leading-[1.6] font-light text-gray-700">
						{h.about_body}
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- 02 — TECHNICAL · PROJECTS -->
	<section id="technical" class="py-28 md:py-40 bg-gray-50 border-b border-gray-200">
		<div class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16">
			<div class="grid md:grid-cols-12 gap-10 md:gap-16 items-end">
				<div class="md:col-span-7">
					<p class="text-[10px] md:text-xs tracking-[0.3em] uppercase text-gray-400 mb-10">02 — {h.technical_eyebrow}</p>
					<h2 class="text-3xl md:text-5xl font-light leading-tight tracking-tight text-gray-900">
						{h.technical_title}
					</h2>
				</div>
				<div class="md:col-span-5">
					<p class="text-base md:text-lg leading-[1.6] font-light text-gray-700 mb-10" set:html={h.technical_body}></p>
					<a href={projectsUrl}
					   class="inline-flex items-center gap-3 text-xs md:text-sm tracking-[0.25em] uppercase text-gray-900 border-b border-gray-900/50 hover:border-gray-900 pb-2 transition-colors">
						<span>{h.technical_cta}</span>
						<span aria-hidden="true">→</span>
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- 03 — REAL ESTATE · INVESTMENT (full-bleed image background) -->
	<section id="investment" class="relative bg-black overflow-hidden">
		<div class="absolute inset-0">
			<Image
				src={palauCover}
				alt="Palau · Barrabisa"
				class="w-full h-full object-cover"
				widths={[1200, 1600, 2000, 2400]}
				sizes="100vw"
			/>
			<div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/50 to-black/25"></div>
		</div>
		<div class="relative min-h-[78vh] md:min-h-[82vh] flex flex-col justify-end">
			<div class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16 w-full pt-32 pb-16 md:pb-24">
				<div class="grid md:grid-cols-12 gap-10 md:gap-16 items-end">
					<div class="md:col-span-7">
						<p class="text-[10px] md:text-xs tracking-[0.35em] uppercase text-white/70 mb-10">03 — {h.investment_eyebrow}</p>
						<h2 class="text-3xl md:text-5xl font-light leading-tight tracking-tight text-white">
							{h.investment_title}
						</h2>
						<div class="mt-8 md:mt-10">
							<div class="flex items-center gap-3 text-[10px] md:text-xs tracking-[0.3em] uppercase text-[#8BC34A] mb-3">
								<span class="w-8 h-px bg-[#8BC34A]"></span>
								<span>{h.investment_featured_label}</span>
							</div>
							<p class="text-sm md:text-base font-light text-white/85">{h.investment_project_tag}</p>
						</div>
					</div>
					<div class="md:col-span-5">
						<p class="text-base md:text-lg leading-[1.6] font-light text-white/85 mb-10" set:html={h.investment_body}></p>
						<a href={realEstateUrl}
						   class="inline-flex items-center gap-3 text-xs md:text-sm tracking-[0.25em] uppercase text-white border-b border-white/50 hover:border-white pb-2 transition-colors">
							<span>{h.investment_cta}</span>
							<span aria-hidden="true">→</span>
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- 04 — SELECTED PARTNERS -->
	<section id="partners" class="py-28 md:py-40 bg-gray-50 border-b border-gray-200">
		<div class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16">
			<div class="grid md:grid-cols-12 gap-10 md:gap-16 items-start mb-16 md:mb-20">
				<div class="md:col-span-7">
					<p class="text-[10px] md:text-xs tracking-[0.3em] uppercase text-gray-400 mb-10">04 — {content.partners.eyebrow}</p>
					<h2 class="text-3xl md:text-5xl font-light leading-tight tracking-tight text-gray-900">
						{content.partners.title}
					</h2>
				</div>
				<div class="md:col-span-5">
					<p class="text-base md:text-lg leading-[1.6] font-light text-gray-700">
						{content.partners.body}
					</p>
				</div>
			</div>
			<div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-gray-200 border-t border-gray-200">
				{content.partners.categories.map((cat: { title: string; description: string }, i: number) => (
					<div class="bg-gray-50 p-8 md:p-10">
						<div class="text-xs tracking-widest text-[#8BC34A] mb-4 tabular-nums">{String(i + 1).padStart(2, '0')}</div>
						<h3 class="text-lg md:text-xl font-light text-gray-900 leading-snug mb-3 tracking-tight">{cat.title}</h3>
						<p class="text-sm text-gray-600 font-light leading-relaxed">{cat.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- NEWS — simplified, borderless cards -->
	<section id="news" class="py-28 md:py-40 bg-white border-b border-gray-200">
		<div class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16">
			<div class="grid md:grid-cols-12 gap-10 md:gap-16 items-end mb-16 md:mb-20">
				<div class="md:col-span-7">
					<p class="text-[10px] md:text-xs tracking-[0.3em] uppercase text-gray-400 mb-10">05 — {content.news.eyebrow}</p>
					<h2 class="text-3xl md:text-5xl font-light leading-tight tracking-tight text-gray-900">
						{content.news.title}
					</h2>
				</div>
				<div class="md:col-span-5 md:text-right">
					<a href={content.news.linkedin_url} target="_blank" rel="noopener"
					   class="inline-flex items-center gap-3 text-xs md:text-sm tracking-[0.25em] uppercase text-gray-900 border-b border-gray-900/50 hover:border-gray-900 pb-2 transition-colors">
						<span>{content.news.linkedin_cta}</span>
						<span aria-hidden="true">→</span>
					</a>
				</div>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-14 border-t border-gray-200 pt-12 md:pt-16">
				{content.news.items.map((item: { date: string; category: string; title: string; description: string; href: string }) => (
					<a href={item.href} target="_blank" rel="noopener" class="group block">
						<div class="flex items-center justify-between mb-6">
							<span class="text-xs tracking-widest uppercase text-gray-400 tabular-nums">{item.date}</span>
							<span class="text-[10px] tracking-[0.2em] uppercase text-gray-400">{item.category}</span>
						</div>
						<h3 class="text-xl md:text-2xl font-light text-gray-900 leading-snug tracking-tight mb-4 group-hover:text-[#8BC34A] transition-colors">{item.title}</h3>
						<p class="text-sm text-gray-600 font-light leading-relaxed">{item.description}</p>
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- CONTACT — minimal -->
	<section id={locale === 'it' ? 'contatti' : 'contact'} class="py-28 md:py-40 bg-[#1a1a1a] text-white">
		<div class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16">
			<div class="grid md:grid-cols-12 gap-10 md:gap-16 items-end">
				<div class="md:col-span-7">
					<p class="text-[10px] md:text-xs tracking-[0.3em] uppercase text-white/40 mb-10">— {content.contatti.eyebrow}</p>
					<h2 class="text-3xl md:text-5xl font-light leading-tight tracking-tight">
						{content.contatti.title}
					</h2>
				</div>
				<div class="md:col-span-5">
					<p class="text-base md:text-lg text-white/70 font-light leading-[1.6] mb-10">{content.contatti.subtitle}</p>
					<a href={`mailto:${content.footer.email_value}`}
					   class="inline-flex items-center gap-4 text-base md:text-lg font-light text-white border-b border-white/50 hover:border-white pb-2 transition-colors">
						<span>{content.footer.email_value}</span>
						<span aria-hidden="true">→</span>
					</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
