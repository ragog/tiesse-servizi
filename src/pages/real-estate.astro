---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTranslations } from '../i18n';
import sardiniaHero from '../assets/real-estate/sardinia-hero.jpg';
import sardegnaTile from '../assets/real-estate/palau-barrabisa/home-hero.jpg';
import toscanaTile from '../assets/real-estate/toscana/cover.jpg';
import corsicaTile from '../assets/real-estate/corsica/cover.jpg';

const locale = 'it';
const content = getTranslations(locale);
const re = content.real_estate;

const locations = [
  { key: 'sardegna', label: 'Sardegna', cover: sardegnaTile, href: '/real-estate/sardegna' },
  { key: 'toscana', label: 'Toscana', cover: toscanaTile, href: null },
  { key: 'corsica', label: 'Corsica', cover: corsicaTile, href: null }
];
---

<BaseLayout content={content} locale={locale} title={`${re.page_title} - ${content.site_title}`} description="Operazioni immobiliari Tiesse Servizi: asset residenziali strutturati per preservare e accrescere il valore nel tempo. Location esclusive in Italia, controllo ingegneristico end-to-end.">
  <!-- PAGE HERO -->
  <section class="relative bg-black overflow-hidden">
    <div class="absolute inset-0">
      <Image
        src={sardiniaHero}
        alt="Real Estate · Sardegna"
        class="w-full h-full object-cover"
        widths={[1200, 1600, 2000, 2400]}
        sizes="100vw"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/40 to-black/80"></div>
    </div>

    <div class="relative min-h-[78vh] md:min-h-[82vh] flex flex-col justify-end">
      <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8 w-full pt-40 pb-16 md:pb-20">
        <div class="grid md:grid-cols-12 gap-10 md:gap-12 items-end">
          <div class="md:col-span-7">
            <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-8xl font-extralight leading-[1.02] sm:leading-[0.95] tracking-[-0.02em] text-white">{re.hero_title}</h1>
          </div>
          <div class="md:col-span-5">
            <p class="text-base md:text-lg leading-[1.55] font-light text-white/85 max-w-xl">{re.hero_subtitle}</p>
          </div>
        </div>
        <div class="mt-10 md:mt-14 flex flex-wrap gap-x-10 gap-y-3 text-[11px] md:text-xs tracking-[0.25em] uppercase text-white/70">
          {re.hero_meta.map((m: string) => (<span>{m}</span>))}
        </div>
      </div>
    </div>
  </section>

  <!-- 01 — INTRO / POSITIONING -->
  <section class="bg-white py-24 md:py-32 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-12 gap-12 items-start">
        <div class="md:col-span-5">
          <p class="text-xs tracking-[0.3em] uppercase text-gray-500 mb-6">01 — {re.intro_eyebrow}</p>
          <h2 class="text-3xl md:text-5xl font-light leading-[1.05] tracking-tight text-gray-900">{re.intro_title}</h2>
        </div>
        <div class="md:col-span-7 space-y-6 text-gray-700 leading-relaxed text-lg font-light">
          {re.intro_body.map((p: string) => (<p>{p}</p>))}
        </div>
      </div>
    </div>
  </section>

  <!-- 02 — OPERATING REGIONS GRID -->
  <section class="bg-white py-20 md:py-28 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8">
      <div class="mb-12 md:mb-16">
        <p class="text-[10px] md:text-xs tracking-[0.3em] uppercase text-gray-500 mb-6">02 — Aree operative</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-5 md:gap-x-6 gap-y-10 md:gap-y-12">
        {locations.map((loc) => {
          const Tag = loc.href ? 'a' : 'div';
          return (
            <Tag
              {...(loc.href ? { href: loc.href } : {})}
              class={`block relative overflow-hidden aspect-[5/4] bg-[#1B5E20] ${loc.href ? 'group' : ''}`}
            >
              {loc.cover && (
                <Image
                  src={loc.cover}
                  alt={loc.label}
                  class={`w-full h-full object-cover ${loc.href ? 'transition-transform duration-700 group-hover:scale-105' : ''}`}
                  widths={[600, 900, 1200, 1600]}
                  sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
                />
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
              <div class="absolute inset-x-0 bottom-0 p-6 md:p-7 text-white flex items-end justify-between gap-4">
                <h3 class="text-xl md:text-2xl font-light leading-tight tracking-tight">{loc.label}</h3>
                {loc.href && (
                  <span class="text-xl md:text-2xl font-light text-white/80 group-hover:text-white transition-colors" aria-hidden="true">→</span>
                )}
              </div>
            </Tag>
          );
        })}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#1B5E20] text-white py-24 md:py-32 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-40 h-40 md:w-56 md:h-56 pointer-events-none opacity-20" aria-hidden="true">
      <svg viewBox="0 0 100 100" class="w-full h-full">
        <polygon points="100,0 100,100 0,0" fill="#ffffff" />
      </svg>
    </div>
    <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8 relative">
      <div class="grid md:grid-cols-12 gap-12 items-end">
        <div class="md:col-span-8">
          <p class="text-xs tracking-[0.3em] uppercase text-white/60 mb-6">{re.cta_eyebrow}</p>
          <h2 class="text-3xl md:text-5xl font-light leading-[1.1] tracking-tight mb-6">{re.cta_title}</h2>
          <p class="text-white/80 leading-relaxed font-light max-w-2xl">{re.cta_body}</p>
        </div>
        <div class="md:col-span-4 md:text-right">
          <a href={`mailto:${content.footer.email_value}`} class="inline-flex items-center gap-3 text-sm tracking-[0.2em] uppercase text-white border-b border-white/50 pb-1 hover:border-white transition-colors">
            {re.cta_button}
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
