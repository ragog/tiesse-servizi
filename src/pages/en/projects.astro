---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectHero from '../../components/ProjectHero.astro';
import CategoryTile from '../../components/CategoryTile.astro';
import { getTranslations } from '../../i18n';
import { getCollection } from 'astro:content';

const locale = 'en';
const content = getTranslations(locale);

const allProjects = await getCollection('projects', ({ id }) => {
  return id.startsWith('en/');
});

const sortProjects = (list: typeof allProjects) =>
  list.sort((a, b) => {
    if (a.data.order !== undefined && b.data.order !== undefined) {
      return a.data.order - b.data.order;
    }
    if (a.data.order !== undefined) return -1;
    if (b.data.order !== undefined) return 1;
    return b.data.year - a.data.year;
  });

const sectorOrder: Array<keyof typeof content.projects.sectors> = [
  'healthcare',
  'historic-renovation',
  'energy-retrofit',
  'residential-development',
  'public-sector'
];

const categoryTiles = sectorOrder
  .map((key) => {
    const items = sortProjects(allProjects.filter((p) => p.data.category === key));
    const flagship = items[0];
    return flagship
      ? {
          key,
          label: content.projects.sectors[key].label,
          description: content.projects.sectors[key].description,
          count: items.length,
          cover: flagship.data.coverImage
        }
      : null;
  })
  .filter((t): t is NonNullable<typeof t> => t !== null);
---

<BaseLayout content={content} locale={locale} title={`${content.projects.page_title} - ${content.site_title}`} description="Tiesse Servizi portfolio: premium residential operations and engineered developments. Technical control, cost control and tracked timelines, from feasibility to handover.">
  <ProjectHero
    eyebrow={content.projects.hero_eyebrow}
    title={content.projects.page_title}
    subtitle={content.projects.subtitle}
    tag={content.projects.hero_tag}
    locale={locale}
  />

  <!-- Stats Strip -->
  <section class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-gray-200">
        {content.projects.stats.map((item: { value: string; label: string }) => (
          <div class="py-12 px-4 md:px-6 text-center">
            <div class="text-3xl md:text-5xl font-light text-gray-900 mb-3 tabular-nums">{item.value}</div>
            <div class="text-[10px] md:text-xs tracking-[0.25em] uppercase text-gray-500">{item.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Portfolio grid -->
  <section class="bg-white py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8">
      <div class="mb-12 md:mb-16">
        <p class="text-[10px] md:text-xs tracking-[0.3em] uppercase text-gray-500 mb-6">{content.projects.categories_eyebrow}</p>
        <h2 class="text-3xl md:text-5xl font-light leading-[1.1] tracking-tight text-gray-900 max-w-3xl mb-4">
          {content.projects.categories_title}
        </h2>
        {content.projects.categories_subtitle && (
          <p class="text-base md:text-lg font-light text-gray-500 max-w-2xl">{content.projects.categories_subtitle}</p>
        )}
      </div>
      {categoryTiles.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-5 md:gap-x-6 gap-y-10 md:gap-y-12">
          {categoryTiles.map((tile) => (
            <div>
              <CategoryTile
                label={tile.label}
                count={tile.count}
                countLabel={tile.count === 1 ? content.projects.category_work_single : content.projects.category_work_plural}
                coverImage={tile.cover}
              />
              <p class="mt-4 text-sm md:text-[15px] leading-[1.55] font-normal text-gray-700">{tile.description}</p>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-center text-gray-600 text-xl">{content.projects.no_projects}</p>
      )}
    </div>
  </section>
</BaseLayout>
