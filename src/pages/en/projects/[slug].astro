---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTranslations } from '../../../i18n';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ id }) => {
    return id.startsWith('en/');
  });

  return projects.map((project) => ({
    params: { slug: project.id.replace('en/', '').replace('.md', '') },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();

const locale = 'en';
const content = getTranslations(locale);

const facts = [
  { label: content.projects.specs_year, value: project.data.year },
  { label: content.projects.specs_location, value: project.data.location },
  { label: content.projects.specs_category, value: project.data.category },
  { label: content.projects.specs_client, value: project.data.specs?.client },
  { label: content.projects.specs_area, value: project.data.specs?.area },
  { label: content.projects.specs_duration, value: project.data.specs?.duration },
].filter((f) => f.value);
---

<BaseLayout content={content} locale={locale} title={`${project.data.title} - ${content.site_title}`}>
  <!-- Breadcrumb / Back -->
  <section class="bg-white border-b border-gray-200 pt-28 md:pt-32 pb-8">
    <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8">
      <a href="/en/projects" class="inline-flex items-center gap-3 text-xs tracking-[0.25em] uppercase text-gray-500 hover:text-black transition-colors">
        <span aria-hidden="true">←</span>
        {content.projects.back_to_projects}
      </a>
    </div>
  </section>

  <!-- Project Title Block -->
  <section class="bg-white pt-12 md:pt-20 pb-12 md:pb-16">
    <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-12 gap-12 items-end">
        <div class="md:col-span-8">
          {project.data.category && (
            <p class="text-xs tracking-[0.3em] uppercase text-gray-500 mb-6 capitalize">{project.data.category}</p>
          )}
          <h1 class="text-4xl md:text-6xl lg:text-7xl font-light leading-[1.05] tracking-tight text-gray-900">
            {project.data.title}
          </h1>
        </div>
        <div class="md:col-span-4 md:text-right">
          <p class="text-sm text-gray-500 tracking-wide">
            <span>{project.data.location}</span>
            <span class="mx-2 text-gray-300">·</span>
            <span class="tabular-nums">{project.data.year}</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Hero Image -->
  <section class="bg-gray-50 py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8">
      <div class="bg-white">
        <Image
          src={project.data.coverImage}
          alt={project.data.title}
          class="w-full h-auto max-h-[80vh] object-contain mx-auto"
          widths={[800, 1200, 1600, 2000]}
          sizes="(max-width: 1280px) 100vw, 1280px"
        />
      </div>
    </div>
  </section>

  <!-- Facts Grid -->
  {facts.length > 0 && (
    <section class="bg-white border-y border-gray-200">
      <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8">
        <div class="py-6 md:py-8">
          <p class="text-xs tracking-[0.3em] uppercase text-gray-500 mb-8">{content.projects.detail_facts}</p>
          <div class="grid grid-cols-2 md:grid-cols-6 gap-y-8 gap-x-6">
            {facts.map((fact) => (
              <div>
                <div class="text-[10px] md:text-xs tracking-[0.2em] uppercase text-gray-500 mb-2">{fact.label}</div>
                <div class="text-base md:text-lg font-light text-gray-900 tabular-nums capitalize">{fact.value}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Description + Narrative -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-4xl mx-auto px-6 sm:px-6 lg:px-8">
      <p class="text-xs tracking-[0.3em] uppercase text-gray-500 mb-8">{content.projects.detail_brief}</p>
      <p class="text-xl md:text-2xl text-gray-900 leading-[1.5] font-light mb-16">
        {project.data.description}
      </p>

      <div class="prose prose-lg max-w-none prose-headings:font-light prose-headings:tracking-tight prose-p:text-gray-700 prose-p:leading-relaxed prose-strong:text-gray-900 prose-strong:font-medium">
        <Content />
      </div>

      {project.data.specs?.features && project.data.specs.features.filter((f: string) => f).length > 0 && (
        <div class="mt-16 border-t border-gray-200 pt-12">
          <p class="text-xs tracking-[0.3em] uppercase text-gray-500 mb-6">{content.projects.specs_features}</p>
          <ul class="space-y-0 border-t border-gray-200">
            {project.data.specs.features.filter((f: string) => f).map((feature: string) => (
              <li class="py-4 border-b border-gray-200 text-gray-800">{feature}</li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </section>

  <!-- Gallery -->
  {project.data.gallery && project.data.gallery.length > 0 && (
    <section class="py-20 md:py-24 bg-gray-50 border-t border-gray-200">
      <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8">
        <p class="text-xs tracking-[0.3em] uppercase text-gray-500 mb-12">{content.projects.detail_gallery}</p>
        <div class="grid md:grid-cols-2 gap-6">
          {project.data.gallery.map((image) => (
            <div class="bg-white">
              <Image
                src={image}
                alt={project.data.title}
                class="w-full h-auto object-contain"
                widths={[600, 900, 1200]}
                sizes="(max-width: 768px) 100vw, 50vw"
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Closing Back Link -->
  <section class="bg-white border-t border-gray-200 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8 text-center">
      <a href="/en/projects" class="inline-flex items-center gap-3 text-sm tracking-[0.25em] uppercase text-gray-900 border-b border-gray-300 pb-1 hover:border-black transition-colors">
        <span aria-hidden="true">←</span>
        {content.projects.back_to_projects}
      </a>
    </div>
  </section>
</BaseLayout>
