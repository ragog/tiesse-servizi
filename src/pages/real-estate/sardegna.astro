---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations } from '../../i18n';
import sardiniaHero from '../../assets/real-estate/sardinia-hero.jpg';
import palauCover from '../../assets/real-estate/palau-barrabisa/hero.jpg';
import featureImg from '../../assets/real-estate/palau-barrabisa/feature.jpg';
import aerial1 from '../../assets/real-estate/palau-barrabisa/aerial-1.jpg';
import aerial2 from '../../assets/real-estate/palau-barrabisa/aerial-2.jpg';
import aerial3 from '../../assets/real-estate/palau-barrabisa/aerial-3.jpg';
import costaParadisoHero from '../../assets/real-estate/costa-paradiso/hero.jpg';

const locale = 'it';
const content = getTranslations(locale);
const re = content.real_estate;
---

<BaseLayout content={content} locale={locale} title={`Sardegna · ${re.page_title} - ${content.site_title}`} description="Sviluppi residenziali di pregio in Sardegna. Palau Barrabisa: cinque ville in un contesto iconico della costa nord-orientale. Controllo ingegneristico dalla fattibilità alla consegna.">
  <!-- PAGE HERO -->
  <section class="relative bg-black overflow-hidden">
    <div class="absolute inset-0">
      <Image
        src={sardiniaHero}
        alt="Real Estate · Sardegna"
        class="w-full h-full object-cover"
        widths={[1200, 1600, 2000, 2400]}
        sizes="100vw"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/40 to-black/80"></div>
    </div>

    <div class="relative min-h-[72vh] md:min-h-[78vh] flex flex-col justify-end">
      <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8 w-full pt-40 pb-16 md:pb-20">
        <a href="/real-estate" class="inline-flex items-center gap-2 text-sm md:text-base tracking-[0.15em] uppercase text-white/80 hover:text-white transition-colors mb-10">
          <span aria-hidden="true">←</span>
          <span>Real Estate</span>
        </a>
        <div class="grid md:grid-cols-12 gap-10 md:gap-12 items-center">
          <div class="md:col-span-7">
            <h1 class="text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-extralight leading-[0.95] tracking-[-0.02em] text-white">{re.sardegna_title}</h1>
          </div>
          <div class="md:col-span-5 space-y-3 md:space-y-4">
            {re.sardegna_body.map((p: string) => (
              <p class="text-sm md:text-base text-white/85 leading-[1.55] font-light">{p}</p>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- OPERATION 01 TITLE CARD — divider between the two hero images -->
  <section class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8 py-14 md:py-20">
      <div class="flex items-center gap-4 md:gap-6 mb-8 md:mb-10">
        <span class="text-[11px] md:text-xs tracking-[0.35em] uppercase text-[#1B5E20] font-medium tabular-nums">01</span>
        <span class="w-8 h-px bg-gray-300"></span>
        <p class="text-[11px] md:text-xs tracking-[0.35em] uppercase text-gray-500">{re.palau_eyebrow}</p>
      </div>
      <div class="grid md:grid-cols-12 gap-8 md:gap-12 items-end">
        <div class="md:col-span-8">
          <h2 class="text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-extralight leading-[0.9] tracking-[-0.02em] text-gray-900 mb-4">{re.palau_title}</h2>
          <p class="text-lg md:text-xl font-light text-gray-500 tracking-tight">{re.palau_subtitle}</p>
        </div>
        <div class="md:col-span-4 md:text-right">
          <div class="flex md:justify-end flex-wrap gap-x-6 gap-y-2 text-[10px] md:text-xs tracking-[0.25em] uppercase text-gray-500">
            {re.palau_meta.map((m: string) => (<span>{m}</span>))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- OPERATION: PALAU · BARRABISA — full-bleed hero cover (clean image) -->
  <section class="relative bg-black overflow-hidden h-[60vh] md:h-[75vh]">
    <Image
      src={palauCover}
      alt={`${re.palau_title} · ${re.palau_subtitle}`}
      class="block w-full h-full object-cover"
      widths={[1200, 1600, 2000, 2400]}
      sizes="100vw"
    />
  </section>

  <!-- Palau — Brief -->
  <section class="bg-white py-14 md:py-20 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-12 gap-12 items-start">
        <div class="md:col-span-5">
          <p class="text-xs tracking-[0.3em] uppercase text-gray-500 mb-6">{re.palau_brief_eyebrow}</p>
          <h3 class="text-3xl md:text-4xl font-light leading-[1.1] tracking-tight text-gray-900">{re.palau_brief_title}</h3>
        </div>
        <div class="md:col-span-7 space-y-5 text-gray-700 leading-relaxed text-base md:text-lg font-light">
          {re.palau_brief_body.map((p: string) => (<p>{p}</p>))}
        </div>
      </div>
    </div>
  </section>

  <!-- Palau — Specs -->
  <section class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8 py-12 md:py-14">
      <p class="text-xs tracking-[0.3em] uppercase text-gray-500 mb-8">{re.palau_specs_label}</p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-y-8 gap-x-8">
        {re.palau_specs_items.map((item: { label: string; value: string }) => (
          <div>
            <div class="text-[10px] md:text-xs tracking-[0.25em] uppercase text-gray-500 mb-3">{item.label}</div>
            <div class="text-lg md:text-xl font-light text-gray-900 leading-snug">{item.value}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Palau — Feature image + quote -->
  <section class="bg-white py-14 md:py-20 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-12 gap-12 items-center">
        <div class="md:col-span-7">
          <Image
            src={featureImg}
            alt={`${re.palau_title} · ${re.palau_subtitle}`}
            class="w-full h-auto"
            widths={[800, 1200, 1600]}
            sizes="(max-width: 768px) 100vw, 60vw"
          />
        </div>
        <div class="md:col-span-5">
          <p class="text-xs tracking-[0.3em] uppercase text-gray-500 mb-6">{re.palau_feature_eyebrow}</p>
          <p class="text-2xl md:text-3xl font-light leading-[1.2] tracking-tight text-gray-900 mb-8">"{re.palau_feature_quote}"</p>
          <p class="text-gray-700 leading-relaxed font-light">{re.palau_feature_body}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Palau — Gallery -->
  <section class="bg-gray-50 py-12 md:py-16 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8">
      <p class="text-xs tracking-[0.3em] uppercase text-gray-500 mb-8">{re.palau_gallery_eyebrow}</p>
      <div class="grid md:grid-cols-2 gap-5 md:gap-6">
        <div>
          <div class="overflow-hidden h-[280px] md:h-[400px]">
            <Image src={aerial1} alt="Palau · Barrabisa — vista aerea del sito" class="w-full h-full object-cover" widths={[600, 900, 1200]} sizes="(max-width: 768px) 100vw, 50vw" />
          </div>
          <p class="text-[10px] md:text-xs tracking-[0.2em] uppercase text-gray-400 mt-3">{re.palau_gallery_captions[0]}</p>
        </div>
        <div>
          <div class="overflow-hidden h-[280px] md:h-[400px]">
            <Image src={aerial2} alt="Palau · Barrabisa — vista aerea sulla costa" class="w-full h-full object-cover" widths={[600, 900, 1200]} sizes="(max-width: 768px) 100vw, 50vw" />
          </div>
          <p class="text-[10px] md:text-xs tracking-[0.2em] uppercase text-gray-400 mt-3">{re.palau_gallery_captions[1]}</p>
        </div>
        <div class="md:col-span-2">
          <Image src={aerial3} alt="Palau · Barrabisa — planimetria dell'area con vista aerea dall'alto" class="w-full h-auto" widths={[800, 1200, 1600, 2000]} sizes="100vw" />
          <p class="text-[10px] md:text-xs tracking-[0.2em] uppercase text-gray-400 mt-3">{re.palau_gallery_captions[2]}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Palau — Closing statement -->
  <section class="bg-white py-14 md:py-20 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8">
      <p class="text-xl md:text-2xl font-light leading-[1.4] tracking-tight text-gray-700 max-w-3xl">{re.palau_closing}</p>
    </div>
  </section>

  <!-- OPERATION 02 TITLE CARD — Costa Paradiso separator -->
  <section class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8 py-16 md:py-24">
      <div class="flex items-center gap-4 md:gap-6 mb-8 md:mb-10">
        <span class="text-[11px] md:text-xs tracking-[0.35em] uppercase text-[#1B5E20] font-medium tabular-nums">02</span>
        <span class="w-8 h-px bg-gray-300"></span>
        <p class="text-[11px] md:text-xs tracking-[0.35em] uppercase text-gray-500">{re.costa_paradiso_eyebrow}</p>
      </div>
      <div class="grid md:grid-cols-12 gap-8 md:gap-12 items-end">
        <div class="md:col-span-8">
          <h2 class="text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-extralight leading-[0.9] tracking-[-0.02em] text-gray-900">{re.costa_paradiso_title}</h2>
        </div>
        <div class="md:col-span-4 md:text-right">
          <div class="flex md:justify-end flex-wrap gap-x-6 gap-y-2 text-[10px] md:text-xs tracking-[0.25em] uppercase text-gray-500">
            {re.costa_paradiso_meta.map((m: string) => (<span>{m}</span>))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Costa Paradiso — full-bleed hero cover (filtered) -->
  <section class="relative bg-black overflow-hidden h-[60vh] md:h-[75vh]">
    <Image
      src={costaParadisoHero}
      alt={re.costa_paradiso_title}
      class="block w-full h-full object-cover saturate-[.7] brightness-[.92] contrast-[1.05]"
      widths={[1200, 1600, 2000, 2400]}
      sizes="100vw"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/15 via-transparent to-black/25 pointer-events-none"></div>
  </section>

  <!-- Costa Paradiso — Brief -->
  <section class="bg-white py-14 md:py-20 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-12 gap-12 items-start">
        <div class="md:col-span-5">
          <p class="text-xs tracking-[0.3em] uppercase text-gray-500 mb-6">{re.costa_paradiso_brief_eyebrow}</p>
          <h3 class="text-3xl md:text-4xl font-light leading-[1.1] tracking-tight text-gray-900">{re.costa_paradiso_brief_title}</h3>
        </div>
        <div class="md:col-span-7 space-y-5 text-gray-700 leading-relaxed text-base md:text-lg font-light">
          {re.costa_paradiso_brief_body.map((p: string) => (<p>{p}</p>))}
        </div>
      </div>
    </div>
  </section>

  <!-- Costa Paradiso — Specs -->
  <section class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8 py-12 md:py-14">
      <p class="text-xs tracking-[0.3em] uppercase text-gray-500 mb-8">{re.costa_paradiso_specs_label}</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-y-8 gap-x-8">
        {re.costa_paradiso_specs_items.map((item: { label: string; value: string }) => (
          <div>
            <div class="text-[10px] md:text-xs tracking-[0.25em] uppercase text-gray-500 mb-3">{item.label}</div>
            <div class="text-lg md:text-xl font-light text-gray-900 leading-snug">{item.value}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#1B5E20] text-white py-24 md:py-32 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-40 h-40 md:w-56 md:h-56 pointer-events-none opacity-20" aria-hidden="true">
      <svg viewBox="0 0 100 100" class="w-full h-full">
        <polygon points="100,0 100,100 0,0" fill="#ffffff" />
      </svg>
    </div>
    <div class="max-w-7xl mx-auto px-6 sm:px-6 lg:px-8 relative">
      <div class="grid md:grid-cols-12 gap-12 items-end">
        <div class="md:col-span-8">
          <p class="text-xs tracking-[0.3em] uppercase text-white/60 mb-6">{re.cta_eyebrow}</p>
          <h2 class="text-3xl md:text-5xl font-light leading-[1.1] tracking-tight mb-6">{re.cta_title}</h2>
          <p class="text-white/80 leading-relaxed font-light max-w-2xl">{re.cta_body}</p>
        </div>
        <div class="md:col-span-4 md:text-right">
          <a href={`mailto:${content.footer.email_value}?subject=Palau%20%C2%B7%20Barrabisa`} class="inline-flex items-center gap-3 text-sm tracking-[0.2em] uppercase text-white border-b border-white/50 pb-1 hover:border-white transition-colors">
            {re.cta_button}
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
